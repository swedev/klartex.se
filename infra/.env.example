# Copy to infra/.env on the server (or set in deploy/deploy.sh).
# Pin a specific backend version — never deploy :latest.
BACKEND_VERSION=0.3.0

# Bearer token required for all write endpoints: POST /render and
# POST/DELETE on /page-templates. Read-only endpoints (/health,
# /templates, /blocks, /page-templates GET) stay public.
# Generate with: openssl rand -hex 32
API_TOKEN=replace-me-with-32-byte-random-hex
